# Copie para `.env` na raiz (o `.env` está no .gitignore).
# Frontend — só a chave pública (nunca coloque a privada em VITE_*).
VITE_VAPID_PUBLIC_KEY=

# Edge Function send-chamado-push — definir também nos Secrets do Supabase em produção.
VAPID_SUBJECT=mailto:exemplo@email.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
